-- =========================================================
-- LIQUIDE : CHOCOLAT
-- =========================================================

local chocolat_def = {
	drawtype = "liquid",
	tiles = {
		{
			name = "candy_chocolat.png",
			backface_culling = false,
		}
	},

	special_tiles = {
		{
			name = "candy_chocolat.png",
			backface_culling = false,
			animation = {
				type = "vertical_frames",
				aspect_w = 16,
				aspect_h = 16,
				length = 2.0,
			},
		},
		{
			name = "candy_chocolat.png",
			backface_culling = true,
			animation = {
				type = "vertical_frames",
				aspect_w = 16,
				aspect_h = 16,
				length = 2.0,
			},
		},
	},

	use_texture_alpha = "blend",
	sunlight_propagates = true,
	paramtype = "light",

	walkable = false,
	pointable = true,
	diggable = false,
	buildable_to = true,

	liquid_viscosity = 10,
	liquid_range = 6,

	post_effect_color = {
		a = 80,
		r = 90,
		g = 45,
		b = 15
